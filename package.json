{
  "name": "imagina-signatures",
  "version": "1.1.3",
  "description": "Professional email signatures for WordPress.",
  "private": true,
  "license": "GPL-2.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint \"assets/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"assets/**/*.{ts,tsx}\"",
    "format": "prettier --write \"assets/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "grapesjs": "^0.21.7",
    "grapesjs-preset-newsletter": "^1.0.2",
    "juice": "^11.0.0",
    "lucide-preact": "^0.469.0",
    "mjml-browser": "^4.15.3",
    "preact": "^10.22.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@wordpress/api-fetch": "^7.6.0",
    "@wordpress/i18n": "^5.6.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^15.7.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
