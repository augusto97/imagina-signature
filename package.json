{
  "name": "imagina-signatures",
  "version": "1.0.0",
  "description": "Professional email signatures for WordPress.",
  "private": true,
  "license": "GPL-2.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint \"assets/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"assets/**/*.{ts,tsx}\"",
    "format": "prettier --write \"assets/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^13.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
