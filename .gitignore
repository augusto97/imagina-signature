# Dependencies
node_modules/
# Composer dev dependencies — the plugin has no runtime composer deps
# (custom PSR-4 autoloader), so vendor/ is dev-only and not committed.
# The lockfile (composer.lock) IS committed for reproducible CI builds.
vendor/

# Build artifacts
# Note: build/ is intentionally NOT ignored — it ships in the plugin ZIP.
dist/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Test coverage
coverage/
.phpunit.result.cache
.phpunit.cache/
phpunit.xml

# OS
*~

# Vite
.vite/
stats.html

# TypeScript
*.tsbuildinfo
