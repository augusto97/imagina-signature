# Dependencies
node_modules/
# Composer dev dependencies — the plugin has no runtime composer deps
# (custom PSR-4 autoloader), so vendor/ is dev-only and not committed.
# The lockfile (composer.lock) IS committed for reproducible CI builds.
vendor/

# Build artifacts
# Note: build/ is intentionally NOT ignored — it ships in the plugin ZIP.
dist/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Test coverage
coverage/
.phpunit.result.cache
.phpunit.cache/
phpunit.xml

# OS
*~

# Vite — ignore the dev-cache `.vite/` (lives in node_modules) but
# explicitly KEEP `build/.vite/manifest.json`. The manifest is the
# source of truth for the asset enqueuers (`ManifestReader`) and MUST
# ship in the plugin ZIP, otherwise hashed asset URLs can't be
# resolved at runtime and the editor / admin pages 404 on their JS.
.vite/
!build/.vite/
!build/.vite/manifest.json
stats.html

# TypeScript
*.tsbuildinfo
