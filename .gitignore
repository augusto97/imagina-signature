# Dependencies
node_modules/
# vendor/ contains dev-only deps (PHPUnit, WPCS, Brain Monkey). The plugin's
# runtime uses a custom PSR-4 autoloader and has no PHP runtime deps.
# CI installs them via `composer install`; the distribution ZIP can ship a
# slimmed `--no-dev` vendor/ when needed (see scripts/build-zip.sh).
vendor/

# Build artifacts. /build IS committed for distribution.
dist/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Test artifacts
.phpunit.result.cache
coverage/
.nyc_output/

# Environment
.env
.env.local

# Composer dev-only
/composer.phar
