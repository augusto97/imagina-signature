<?xml version="1.0"?>
<ruleset name="ImaginaSignatures">
	<description>WPCS-based ruleset for the Imagina Signatures plugin.</description>

	<!-- Scan src/ and the main plugin file. -->
	<file>./imagina-signatures.php</file>
	<file>./uninstall.php</file>
	<file>./src</file>

	<!-- Skip third-party / build output. -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>*/dist/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>

	<arg value="sp"/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>
	<arg name="basepath" value="."/>
	<arg name="parallel" value="8"/>

	<!-- CI passes when there are no errors. Warnings (e.g. base64_encode
	     used in cryptography, file_get_contents on local JSON, parse_url
	     within our own SigV4 signer) are reviewed but not blocking. -->
	<config name="ignore_warnings_on_exit" value="1"/>

	<!-- Configuration. -->
	<config name="minimum_supported_wp_version" value="6.0"/>
	<config name="testVersion" value="7.4-"/>

	<!-- WordPress Coding Standards. -->
	<rule ref="WordPress">
		<!-- We use a custom PSR-4 autoloader; class-name-to-filename rules don't apply. -->
		<exclude name="WordPress.Files.FileName"/>

		<!-- short-description docblock requirement is overkill for internal helper methods. -->
		<exclude name="Generic.Commenting.DocComment.MissingShort"/>

		<!-- Modern PHP convention; short array syntax is allowed everywhere we ship. -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>

		<!-- DI containers / pagination helpers conventionally use `$abstract`
		     and `$default` as parameter names. -->
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>

		<!-- Modern syntax. Allowed. -->
		<exclude name="Universal.Operators.DisallowShortTernary"/>

		<!-- Exception messages never reach the rendered page (controllers
		     translate them into WP_Error). The escape-on-throw sniff is
		     a false positive for this code path. -->
		<exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>

		<!-- Plugin hook prefix uses slashes (`imgsig/plugin/booted`) per
		     CLAUDE.md §5.7. The default sniff prefers underscores. -->
		<exclude name="WordPress.NamingConventions.ValidHookName"/>

		<!-- Dynamic hook names like `admin_post_imgsig_save_storage` are
		     properly prefixed but the static analyser can't see through
		     concatenation. -->
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.DynamicHooknameFound"/>

		<!-- A method that always throws is a legitimate pattern (e.g.
		     interface implementations that explicitly opt out of a
		     contract). The "no return statement for non-void function"
		     sniff is a stylistic complaint, not a correctness issue. -->
		<exclude name="Squiz.Commenting.FunctionComment.InvalidNoReturn"/>
	</rule>

	<rule ref="WordPress-Extra">
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>
		<exclude name="Universal.Operators.DisallowShortTernary"/>
		<exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>
		<exclude name="WordPress.NamingConventions.ValidHookName"/>
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.DynamicHooknameFound"/>
		<exclude name="Squiz.Commenting.FunctionComment.InvalidNoReturn"/>
	</rule>
	<rule ref="WordPress-Docs"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- Repositories are dedicated to $wpdb->prepare() with table names
	     resolved through a method call ({$this->table()}). PHPCS's
	     static analyser can't trace the constant prefix and emits
	     PreparedSQL.NotPrepared / InterpolatedNotPrepared at every
	     query. Suppressing these specific sniffs file-wide for the
	     Repositories/ directory keeps the protection elsewhere. -->
	<rule ref="WordPress.DB.PreparedSQL.NotPrepared">
		<exclude-pattern>*/src/Repositories/*</exclude-pattern>
	</rule>
	<rule ref="WordPress.DB.PreparedSQL.InterpolatedNotPrepared">
		<exclude-pattern>*/src/Repositories/*</exclude-pattern>
	</rule>
	<rule ref="WordPress.DB.DirectDatabaseQuery">
		<exclude-pattern>*/src/Repositories/*</exclude-pattern>
		<exclude-pattern>*/src/Core/Uninstaller.php</exclude-pattern>
	</rule>
	<rule ref="WordPress.DB.SlowDBQuery">
		<exclude-pattern>*/src/Repositories/*</exclude-pattern>
	</rule>

	<!-- EditorIframeController explicitly composes raw HTML and headers
	     for the iframe response (CLAUDE.md §14.2). wp_enqueue_* is not
	     applicable. AdminAppPage similarly mounts the React admin app
	     by emitting the script + style tags inline so the React DOM
	     is the only thing on the page. -->
	<rule ref="WordPress.WP.EnqueuedResources">
		<exclude-pattern>*/src/Api/Controllers/EditorIframeController.php</exclude-pattern>
		<exclude-pattern>*/src/Admin/AdminAppPage.php</exclude-pattern>
	</rule>
	<rule ref="WordPress.Security.EscapeOutput.OutputNotEscaped">
		<exclude-pattern>*/src/Api/Controllers/EditorIframeController.php</exclude-pattern>
		<exclude-pattern>*/src/Admin/AdminAppPage.php</exclude-pattern>
	</rule>

	<!-- Text domain check. -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="imagina-signatures"/>
			</property>
		</properties>
	</rule>

	<!-- Hook prefix check. -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="imgsig"/>
				<element value="ImaginaSignatures"/>
			</property>
		</properties>
	</rule>

	<!-- Allow PSR-4 short open echo and namespaces. -->
	<rule ref="WordPress.Files.FileName.InvalidClassFileName">
		<severity>0</severity>
	</rule>
</ruleset>
